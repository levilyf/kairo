{
  "name": "@kairo/provider-registry",
  "version": "0.1.0",
  "description": "Configuration-driven provider factory and model-indexing layer. Bridges @kairo/config and provider packages. Not part of Core.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@kairo/config": "0.1.0",
    "@kairo/core": "0.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
