{
  "name": "@kairo/chat",
  "version": "0.1.0",
  "description": "Streaming chat engine, JSONL session store, progressive renderer, and REPL for Kairo. Depends on Core + App; owns no providers, config loading, or CLI parsing.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kairo/app": "0.1.0",
    "@kairo/core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
