{
  "name": "@kairo/config",
  "version": "0.1.0",
  "description": "Standalone configuration discovery, loading, validation, and environment resolution for Kairo projects",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
